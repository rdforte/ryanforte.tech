		"@tailwindcss/typography": "^0.5.13",
		"babel-loader": "^9.1.3",
		"core-js": "^3.37.0",
		"css-loader": "^7.1.1",
		"mini-css-extract-plugin": "^2.9.0",
		"npm-run-all": "^4.1.5",
		"postcss-loader": "^8.1.1",
		"style-loader": "^4.0.0",
		"tailwindcss": "^3.4.3",
		"webpack": "^5.91.0",
		"webpack-cli": "^5.1.4",
		"webpack-merge": "^5.10.0"
	}
